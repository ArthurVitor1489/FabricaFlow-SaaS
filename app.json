{
  "expo": {
    "name": "FabricaFlow",
    "slug": "sofa-chair-factory-manager",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "plugins": [
      "expo-router"
    ],
    "scheme": "fabricaflow",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#0b0c10"
    },
    "android": {
      "package": "com.fabricaflow.app",
      "adaptiveIcon": {
        "backgroundColor": "#0b0c10"
      }
    },
    "web": {
      "bundler": "metro"
    }
  }
}
